{
  "preset": "ts-jest/presets/default-esm",
  "extensionsToTreatAsEsm": [".ts"],
  "testEnvironment": "node",
  "roots": ["<rootDir>/tests"],
  "testMatch": [
    "**/tests/**/*.test.ts"
  ],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/setup/**/*",
    "!src/index.ts"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": [
    "text",
    "text-summary",
    "lcov",
    "html"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 85,
      "functions": 95,
      "lines": 90,
      "statements": 90
    },
    "src/classes/": {
      "branches": 90,
      "functions": 100,
      "lines": 95,
      "statements": 95
    },
    "src/database/adapters/": {
      "branches": 88,
      "functions": 95,
      "lines": 92,
      "statements": 92
    }
  },
  "setupFilesAfterEnv": [
    "<rootDir>/tests/setup.ts"
  ],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.ts$": [
      "ts-jest",
      {
        "useESM": true
      }
    ]
  },
  "testTimeout": 10000,
  "maxWorkers": 1
}
