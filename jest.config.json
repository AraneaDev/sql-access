{
  "testEnvironment": "node",
  "roots": ["<rootDir>/tests"],
  "testMatch": [
    "**/tests/**/*.test.ts"
  ],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/setup/**/*",
    "!src/index.ts",
    "!src/install.ts",
    "!src/setup.ts",
    "!src/types/**/*"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": [
    "text",
    "text-summary",
    "lcov",
    "html"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 10,
      "functions": 15,
      "lines": 15,
      "statements": 15
    }
  },
  "setupFilesAfterEnv": [
    "<rootDir>/tests/setup.ts"
  ],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.ts$": [
      "@swc/jest",
      {
        "jsc": {
          "parser": {
            "syntax": "typescript",
            "decorators": true
          },
          "target": "es2022"
        },
        "module": {
          "type": "commonjs"
        }
      }
    ]
  },
  "testTimeout": 10000,
  "maxWorkers": 1
}
