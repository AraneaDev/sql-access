{
  "mcpServers": {
    "sql-database": {
      "command": "sql-server",
      "args": []
    }
  }
}

// Advanced Claude Desktop Configuration for SQL MCP Server
//
// This configuration demonstrates advanced options including:
// - Custom config file location
// - Environment-based settings
// - Performance tuning parameters
// - Debug options
//
// SETUP INSTRUCTIONS:
//
// 1. UPDATE ALL PATHS:
//    Replace both paths with your actual file locations:
//    - "/absolute/path/to/sql-access/dist/index.js"
//    - "/absolute/path/to/your/config.ini"
//
// 2. CUSTOMIZE ENVIRONMENT VARIABLES:
//    
//    NODE_ENV:
//    - "production" for production use
//    - "development" for development/debugging
//    
//    CONFIG_PATH:
//    - Absolute path to your config.ini file
//    - Useful if config is not in the project root
//    
//    LOG_LEVEL:
//    - "error" for errors only
//    - "warn" for warnings and errors  
//    - "info" for general information (recommended)
//    - "debug" for detailed debugging
//    
//    MAX_CONNECTIONS:
//    - Maximum concurrent database connections
//    - Default: 5, Range: 1-20
//    
//    QUERY_TIMEOUT:
//    - Query timeout in milliseconds
//    - Default: 30000 (30 seconds)
//    
//    DEBUG_QUERIES:
//    - "true" to log all SQL queries
//    - "false" to disable query logging (recommended for production)
//
// 3. COPY TO CLAUDE DESKTOP CONFIG:
//    macOS:
//    cp examples/claude-integrations/claude-desktop/advanced-config.json \
//       ~/Library/Application\ Support/Claude/claude_desktop_config.json
//    
//    Windows:
//    copy examples\claude-integrations\claude-desktop\advanced-config.json \
//         %APPDATA%\Claude\claude_desktop_config.json
//    
//    Linux:
//    cp examples/claude-integrations/claude-desktop/advanced-config.json \
//       ~/.config/Claude/claude_desktop_config.json
//
// 4. RESTART CLAUDE DESKTOP
//
// PERFORMANCE TUNING NOTES:
//
// For High-Volume Usage:
// - Increase MAX_CONNECTIONS to 15-20
// - Increase QUERY_TIMEOUT for complex queries
// - Set LOG_LEVEL to "warn" to reduce logging overhead
//
// For Development:
// - Set NODE_ENV to "development"
// - Set DEBUG_QUERIES to "true"
// - Set LOG_LEVEL to "debug"
//
// For Production:
// - Set NODE_ENV to "production"
// - Set DEBUG_QUERIES to "false"
// - Set LOG_LEVEL to "info" or "warn"
// - Use SELECT-only mode in config.ini
//
// SECURITY CONSIDERATIONS:
// - Keep CONFIG_PATH secure and not world-readable
// - Use SELECT-only mode for production databases
// - Monitor LOG_LEVEL in production (avoid "debug")
// - Regularly review connection patterns and usage