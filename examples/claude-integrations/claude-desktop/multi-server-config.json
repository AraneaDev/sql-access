{
  "mcpServers": {
    "sql-database-prod": {
      "command": "mcp-sql-server",
      "args": [],
      "env": {
        "CONFIG_PATH": "/path/to/production-config.ini"
      }
    },
    "sql-database-dev": {
      "command": "mcp-sql-server", 
      "args": [],
      "env": {
        "CONFIG_PATH": "/path/to/development-config.ini"
      }
    },
    "file-server": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/documents"],
      "env": {}
    },
    "web-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "your-brave-api-key"
      }
    }
  }
}

// Multi-Server Claude Desktop Configuration
//
// This configuration shows how to run multiple MCP servers simultaneously,
// including multiple SQL MCP Server instances for different environments.
//
// CONFIGURATION BREAKDOWN:
//
// sql-database-prod:
// - Production SQL server with restricted logging
// - Uses production database configuration
// - Optimized for performance and security
//
// sql-database-dev:
// - Development SQL server with debug logging
// - Uses development database configuration
// - Enables query debugging and detailed logs
//
// file-server:
// - Provides file system access for documents
// - Useful for analyzing CSV/Excel files alongside database queries
//
// web-search:
// - Enables web search capabilities
// - Can be used to find documentation or troubleshooting info
//
// SETUP INSTRUCTIONS:
//
// 1. UPDATE ALL PATHS:
//    Replace all "/path/to/" placeholders with actual paths
//
// 2. CREATE SEPARATE CONFIG FILES:
//    production-config.ini:
//    - Production databases with SELECT-only mode
//    - Conservative security settings
//    - Production connection strings
//    
//    development-config.ini:
//    - Development databases with full access
//    - Relaxed security settings for testing
//    - Local/development connection strings
//
// 3. CONFIGURE ADDITIONAL SERVERS (optional):
//    - Get Brave API key for web search: https://brave.com/search/api/
//    - Set document path for file server
//    - Remove unused servers if not needed
//
// 4. USAGE EXAMPLES:
//    
//    Production Queries:
//    "Show me today's sales from the production database"
//    "What are the current user counts in prod?"
//    
//    Development Queries:
//    "Test this query on the dev database first"
//    "Show me the development schema changes"
//    
//    Multi-Server Queries:
//    "Compare user counts between prod and dev databases"
//    "Search the web for PostgreSQL best practices, then check our prod config"
//    "Analyze this CSV file and compare it to our database"
//
// 5. SECURITY CONSIDERATIONS:
//    - Production config should use SELECT-only mode
//    - Use different database users for prod vs dev
//    - Monitor logs for both servers
//    - Secure API keys and configuration files
//
// 6. PERFORMANCE NOTES:
//    - Running multiple servers increases resource usage
//    - Consider different timeout values for prod vs dev
//    - Monitor connection limits on database servers
//    - Stagger heavy operations between environments
//
// TROUBLESHOOTING:
// - If servers conflict, check port usage
// - Verify all config files exist and are valid
// - Test each server individually first
// - Check Claude Desktop logs for startup errors