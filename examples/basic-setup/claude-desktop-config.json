//   "mcpServers": {
//     "sql-database": {
//       "command": "node",
//       "args": ["/path/to/your/sql-access/dist/index.js"],
//       "env": {
//         "NODE_ENV": "production"
//       }
//     }
//   }
// }

// Instructions for Claude Desktop Integration:
//
// 1. Locate your Claude Desktop config file:
//    - macOS: ~/Library/Application Support/Claude/claude_desktop_config.json
//    - Windows: %APPDATA%\Claude\claude_desktop_config.json
//    - Linux: ~/.config/Claude/claude_desktop_config.json
//
// 2. Choose the appropriate configuration method above:
//    - Global installation: Use "sql-server" command (easiest)
//    - Local project: Use "npx sql-server" with cwd
//    - Development: Use "node" with full path to dist/index.js
//
// 3. For development installations, update the path:
//    - Replace "/path/to/your/sql-access" with the actual path
//    - Example: "/Users/yourname/sql-access/dist/index.js"
//    - Windows example: "C:\\Users\\yourname\\sql-access\\dist\\index.js"
//
// 4. Ensure your config.ini is in the project root directory
//
// 5. For source installations, build the project:
//    npm run build
//
// 6. Restart Claude Desktop
//
// 7. Test the integration by asking Claude:
//    "What databases do you have access to?"
//    "Show me the tables in [database_name]"
//
// Troubleshooting:
// - Check Claude Desktop logs for connection errors
// - Verify file paths are correct and accessible
// - Ensure config.ini exists and is valid
// - Check that Node.js and npm are in PATH
// - Restart Claude Desktop after config changes