{
  "name": "sql-access",
  "version": "2.5.1",
  "description": "MCP server for accessing SQL databases, with support for PostgreSQL, MySQL, SQLite, MSSQL, and SSH tunnels",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-sql-server": "./dist/index.js",
    "mcp-sql-setup": "./dist/setup.js",
    "mcp-sql-install": "./dist/install.js"
  },
  "scripts": {
    "build": "npm run clean && tsc && chmod +x dist/index.js dist/setup.js dist/install.js",
    "build:fast": "npm run clean && npm run build:esbuild",
    "build:esbuild": "esbuild src/index.ts src/setup.ts src/install.ts --bundle --platform=node --outdir=dist --external:mssql --external:mysql2 --external:pg --external:sqlite3 --external:ssh2 --external:ini --format=esm --sourcemap --minify && chmod +x dist/index.js dist/setup.js dist/install.js",
    "build:production": "npm run clean && npm run lint && npm run test && npm run build",
    "build:watch": "tsc --watch",
    "dev": "npm run build:watch",
    "start": "node dist/index.js",
    "setup": "node dist/setup.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest tests/unit --passWithNoTests",
    "test:integration": "jest tests/integration --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src/**/*.ts --fix",
    "lint:check": "eslint src/**/*.ts",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "type-check": "tsc --noEmit",
    "clean": "node -e \"const fs = require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist', {recursive: true, force: true});\"",
    "prebuild": "npm run type-check",
    "validate": "npm run lint:check && npm run format:check && npm run type-check && npm run test",
    "validate-docs": "node scripts/validate-documentation.js",
    "prepack": "npm run build:production",
    "generate-template": "node dist/setup.js --template",
    "install-mcp": "node dist/install.js"
  },
  "keywords": [
    "claude",
    "mcp",
    "sql",
    "database",
    "postgresql",
    "mysql",
    "sqlite",
    "mssql",
    "typescript",
    "ai"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ini": "^4.1.1",
    "mssql": "^10.0.1",
    "mysql2": "^3.6.0",
    "pg": "^8.11.0",
    "sqlite3": "^5.1.6",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "@types/ini": "^4.0.0",
    "@types/jest": "^29.0.0",
    "@types/mssql": "^9.1.7",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.0.0",
    "@types/sqlite3": "^3.0.0",
    "@types/ssh2": "^1.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "jest": "^29.0.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "node": ">=16.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "plugins": [
      "@typescript-eslint",
      "jsdoc"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:jsdoc/recommended-typescript-flavor"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "env": {
      "node": true,
      "es2022": true
    },
    "globals": {
      "process": "readonly",
      "console": "readonly",
      "Buffer": "readonly",
      "setTimeout": "readonly",
      "__dirname": "readonly",
      "__filename": "readonly"
    },
    "rules": {
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }
      ],
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/no-empty-function": "warn",
      "@typescript-eslint/consistent-type-imports": [
        "warn",
        {
          "prefer": "type-imports"
        }
      ],
      "prefer-const": "error",
      "no-console": [
        "warn",
        {
          "allow": [
            "error"
          ]
        }
      ],
      "no-useless-escape": "warn",
      "eqeqeq": [
        "error",
        "always"
      ],
      "no-throw-literal": "error",
      "jsdoc/require-jsdoc": [
        "warn",
        {
          "publicOnly": true,
          "require": {
            "FunctionDeclaration": true,
            "MethodDefinition": true,
            "ClassDeclaration": true
          },
          "checkConstructors": false
        }
      ],
      "jsdoc/require-description": "off",
      "jsdoc/require-param-type": "off",
      "jsdoc/require-returns-type": "off",
      "jsdoc/require-returns": "off",
      "jsdoc/require-param": "off",
      "jsdoc/require-param-description": "off"
    },
    "ignorePatterns": [
      "dist/",
      "node_modules/",
      "coverage/",
      "examples/"
    ]
  }
}
